<Window
    x:Class="SoundCore.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:SoundCore.UI.Pages"
    xmlns:animation="using:Microsoft.UI.Xaml.Media.Animation"
    Title="SoundCore">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Connection status banner -->
        <InfoBar x:Name="ConnectionBanner"
                 Grid.Row="0"
                 IsOpen="False"
                 IsClosable="False"
                 Severity="Warning"
                 Margin="12,8,12,0" />

        <NavigationView x:Name="Nav"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        IsTitleBarAutoPaddingEnabled="True"
                        PaneDisplayMode="LeftCompact"
                        SelectionChanged="Nav_OnSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavDevices" Tag="devices">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE767;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavPerApp" Tag="perapp">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE71D;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavVst" Tag="vst">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE7F4;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavMicLock" Tag="miclock">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE720;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavCamera" Tag="camera">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE722;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <animation:NavigationThemeTransition>
                            <animation:NavigationThemeTransition.DefaultNavigationTransitionInfo>
                                <animation:SlideNavigationTransitionInfo Effect="FromRight" />
                            </animation:NavigationThemeTransition.DefaultNavigationTransitionInfo>
                        </animation:NavigationThemeTransition>
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
