<Page
    x:Class="SoundCore.UI.Pages.MicLockPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:proto="using:Soundcore.V1"
    xmlns:loc="using:SoundCore.UI.Localization">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="14" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="32" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <StackPanel Spacing="2">
                <TextBlock Text="{loc:Str Key=MicLock_Title}" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="{loc:Str Key=MicLock_Subtitle}" />
            </StackPanel>

            <ToggleSwitch x:Name="EnableSwitch"
                          Header="{loc:Str Key=MicLock_Enable}"
                          Toggled="EnableSwitch_OnToggled" />

            <ComboBox x:Name="DeviceCombo"
                      Header="{loc:Str Key=MicLock_Device}"
                      Width="420"
                      DisplayMemberPath="FriendlyName"
                      SelectionChanged="DeviceCombo_OnSelectionChanged" />

            <StackPanel Spacing="4">
                <TextBlock Text="{loc:Str Key=MicLock_Volume}"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Slider x:Name="VolumeSlider"
                        Minimum="0" Maximum="100" Width="420"
                        StepFrequency="1"
                        SnapsTo="Ticks"
                        ValueChanged="VolumeSlider_OnValueChanged" />
                <TextBlock x:Name="VolumeText" Text="100%"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ToggleSwitch x:Name="LockMuteSwitch"
                          Header="{loc:Str Key=MicLock_LockMute}"
                          Toggled="LockMuteSwitch_OnToggled" />

            <StackPanel Spacing="4">
                <TextBlock Text="{loc:Str Key=MicLock_Whitelist}"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           TextWrapping="Wrap" />
                <TextBox x:Name="WhitelistBox"
                         Height="120"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         PlaceholderText="OBS64.exe&#x0d;&#x0a;Streamlabs*.exe" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <InfoBadge x:Name="NeedDeviceBadge" Visibility="Collapsed" />
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button x:Name="ApplyButton"
                        Style="{ThemeResource AccentButtonStyle}"
                        Content="{loc:Str Key=Common_Apply}"
                        Click="Apply_OnClick" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
