<Page
    x:Class="SoundCore.UI.Pages.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:proto="using:Soundcore.V1"
    xmlns:loc="using:SoundCore.UI.Localization">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="24" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>
            <TextBlock Text="{loc:Str Key=Devices_Title}"
                       Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="{loc:Str Key=Devices_Subtitle}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Pivot Grid.Row="1" x:Name="FlowPivot" SelectionChanged="FlowPivot_OnSelectionChanged">
            <PivotItem x:Name="PlaybackPivot" Tag="render" />
            <PivotItem x:Name="CapturePivot" Tag="capture" />
        </Pivot>

        <ProgressRing Grid.Row="2" x:Name="LoadingRing" IsActive="False"
                      Width="22" Height="22" HorizontalAlignment="Left" Margin="0,4" />

        <ListView Grid.Row="3"
                  x:Name="DeviceList"
                  SelectionMode="Single"
                  IsItemClickEnabled="True">
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <AddDeleteThemeTransition />
                    <ContentThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="proto:AudioDevice">
                    <StackPanel Orientation="Horizontal" Spacing="12" Padding="0,8">
                        <FontIcon Glyph="&#xE767;" FontSize="18"
                                  VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="{x:Bind FriendlyName}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock>
                                <Run Text="{x:Bind SampleRate}" /> Hz · <Run Text="{x:Bind ChannelCount}" />ch ·
                                <Run Text="{x:Bind BitsPerSample}" />-bit
                            </TextBlock>
                        </StackPanel>
                        <Border CornerRadius="999"
                                Padding="6,2"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind IsDefault}">
                            <TextBlock Text="{loc:Str Key=Devices_Default}"
                                       FontSize="11"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" x:Name="EmptyState"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8" MaxWidth="360">
            <FontIcon Glyph="&#xE767;" FontSize="40"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="{loc:Str Key=Devices_Empty_Title}"
                       HorizontalAlignment="Center"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBlock Text="{loc:Str Key=Devices_Empty_Text}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
