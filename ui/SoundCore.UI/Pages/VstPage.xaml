<Page
    x:Class="SoundCore.UI.Pages.VstPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:proto="using:Soundcore.V1"
    xmlns:loc="using:SoundCore.UI.Localization">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="24" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>
            <TextBlock Text="{loc:Str Key=Vst_Title}" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="{loc:Str Key=Vst_Subtitle}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <Button x:Name="RescanButton" Content="{loc:Str Key=Vst_Rescan}" Click="Rescan_OnClick" />
            <ProgressRing x:Name="ScanProgress" Width="20" Height="20" IsActive="False" />
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ListView Grid.Row="3" x:Name="PluginList" SelectionMode="Single">
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <AddDeleteThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="proto:VstPluginInfo">
                    <Grid Padding="0,6" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Name}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Vendor}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind Category}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind Path}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" x:Name="EmptyState"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8" MaxWidth="420">
            <FontIcon Glyph="&#xE7F4;" FontSize="40"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="{loc:Str Key=Vst_Empty_Title}"
                       HorizontalAlignment="Center"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <TextBlock Text="{loc:Str Key=Vst_Empty_Text}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
