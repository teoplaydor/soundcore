<Page
    x:Class="SoundCore.UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:SoundCore.UI.Localization">

    <Page.Resources>
        <Style x:Key="SettingsCard" TargetType="Grid">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="ColumnSpacing" Value="16" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="8" MaxWidth="760" HorizontalAlignment="Left">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="40" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <TextBlock Text="{loc:Str Key=Settings_Title}"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Margin="0,0,0,8" />

            <!-- Appearance -->
            <TextBlock Text="{loc:Str Key=Settings_Appearance}" Style="{StaticResource SectionHeader}" />

            <Grid Style="{StaticResource SettingsCard}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xF2B7;" FontSize="18" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{loc:Str Key=Settings_Language}" />
                    <TextBlock Text="{loc:Str Key=Settings_LanguageHint}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
                <ComboBox Grid.Column="2" x:Name="LanguageCombo"
                          MinWidth="220" VerticalAlignment="Center"
                          SelectionChanged="LanguageCombo_OnSelectionChanged" />
            </Grid>

            <Grid Style="{StaticResource SettingsCard}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE790;" FontSize="18" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{loc:Str Key=Settings_Theme}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="2" x:Name="ThemeCombo"
                          MinWidth="220" VerticalAlignment="Center"
                          SelectionChanged="ThemeCombo_OnSelectionChanged" />
            </Grid>

            <!-- Service -->
            <TextBlock Text="{loc:Str Key=Settings_Service}" Style="{StaticResource SectionHeader}" />

            <Grid Style="{StaticResource SettingsCard}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" x:Name="ServiceIcon" Glyph="&#xEA3A;" FontSize="18" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{loc:Str Key=Settings_ServiceState}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" x:Name="ServiceStateText" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <!-- About -->
            <TextBlock Text="{loc:Str Key=Settings_About}" Style="{StaticResource SectionHeader}" />

            <Grid Style="{StaticResource SettingsCard}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE946;" FontSize="18" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="SoundCore" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="VersionText"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
